# Plantilla de variables de entorno — copia a .env y rellena los valores.
# .env está en .gitignore: NUNCA se versiona.

# OpenRouter (gateway unificado: Kimi, Claude, DeepSeek, etc.)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Proveedores directos (opcionales, si no usas el gateway)
# MOONSHOT_API_KEY=        # Kimi oficial -> https://api.moonshot.ai/v1
# DEEPSEEK_API_KEY=        # -> https://api.deepseek.com/v1
# ANTHROPIC_API_KEY=       # OJO: no dejar en entorno global (ver reporte, sección 6)
